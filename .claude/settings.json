{
  "permissions": {
    "allow": [
      "Bash(jira issue view *)",
      "Bash(jira issue list *)",
      "Bash(./lint-docs.sh *)",
      "Bash(skill-validator check *)",
      "mcp__glean_default__search",
      "mcp__glean_default__read_document",
      "mcp__mcp-atlassian__jira_get_issue",
      "mcp__mcp-atlassian__jira_get_transitions",
      "mcp__mcp-atlassian__confluence_get_page_children"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(test(\"\\\\.claude/hooks/\"))' | { read -r f; [ -n \"$f\" ] && chmod +x \"$f\"; } 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/toc-write-hook.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/toc-bash-hook.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-redirects-needed.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/dochub-drift-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/vale-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/nested-components-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [[ \"$f\" == *OWNERS.yaml ]] && python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/generate-readme.py\"; } 2>/dev/null || true",
            "statusMessage": "Regenerating skills README..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-existing-branch-commits.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-git-best-practices.sh"
          },
          {
            "type": "command",
            "if": "Bash(git merge*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-merge-workflow.sh"
          },
          {
            "type": "command",
            "if": "Bash(git checkout*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-branch-creation.sh"
          },
          {
            "type": "command",
            "if": "Bash(git fetch origin && git checkout*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-branch-creation.sh"
          },
          {
            "type": "command",
            "if": "Bash(git switch*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-branch-creation.sh"
          },
          {
            "type": "command",
            "if": "Bash(git fetch origin && git switch*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-branch-creation.sh"
          },
          {
            "type": "command",
            "if": "Bash(git branch*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-branch-creation.sh"
          },
          {
            "type": "command",
            "if": "Bash(git fetch origin && git branch*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-git-process-hooks/check-branch-creation.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-push-missing-redirects.sh"
          },
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/pr-size-check.py"
          }
        ]
      }
    ]
  }
}
