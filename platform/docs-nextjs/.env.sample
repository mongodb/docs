# Snooty env
MONGODB_URI=mongodb+srv://<user>:<password>@<host>
DB_ENV=dev
SNOOTY_DB_NAME=snooty_dotcomprd
# ContentStack env
CONTENTSTACK_API_KEY=some-api-key
CONTENTSTACK_ENVIRONMENT=dev
CONTENTSTACK_DELIVERY_TOKEN=some-token
CONTENTSTACK_WEBHOOK_TOKEN=some-token
# Jira env
JIRA_USERNAME=johndoe
JIRA_PASSWORD=password
# Slack env
SLACK_QUOKKA_OAUTH_ACCESS_TOKEN=some-token
# For offline build
NETLIFY_ACCESS_TOKEN=some-token
NETLIFY_SITE_ID=nextjs-docs-site-id