{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mongodb": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mongodb-mcp-server", 
        "--readOnly"
      ],
      "enabled": true,
      "environment": {
        "MDB_MCP_CONNECTION_STRING": "<connection-string>"
      }
    }
  }
}