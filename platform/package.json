{
  "name": "platform",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "install:clean": "./tools/clean-install.sh",
    "dev": "node scripts/select-project.mjs",
    "build": "turbo run build",
    "build:offline": "turbo run build:offline",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:update": "turbo run test:update",
    "test:watch": "turbo run test:watch",
    "convert:rst-to-mdx": "turbo run convert:rst-to-mdx",
    "validate:mdx-parse": "turbo run validate:mdx-parse"
  },
  "devDependencies": {
    "jest": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@leafygreen-ui/emotion": "5.1.0"
    }
  }
}