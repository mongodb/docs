db.embedded_movies.aggregate([
  {
    "$match": {
      "fullplot": { "$exists": true, "$type": "string" }
    }
  },
  {
        "$sort": { "released": -1 }
  },
  {
    "$rerank": {
      "model": "rerank-2.5",
      "query": {
        "text": "martial arts; prioritize films about martial arts training and tournaments"
      },
      "path": "fullplot",
      "numDocsToRerank": 100
    }
  },
  {
    "$addFields": {
      "rerankScore": { "$meta": "score" }
    }
  },
  { "$limit": 10 },
  {
    "$project": {
      "_id": 0,
      "title": 1,
      "fullplot": 1,
      "rerankScore": 1
    }
  }
])