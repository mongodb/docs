{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NPM_BASE_64_AUTH", "NPM_EMAIL", "DOCS_PROJECT"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build:toc", "build:prefix-map"]
    },
    "build:toc": {
      "outputs": ["./src/context/toc-data/data.copied.ts"]
    },
    "build:prefix-map": {
      "outputs": ["./src/generated/prefix-map.json"]
    },
    "build": {
      "dependsOn": [
        "^build",
        "typecheck",
        "lint",
        "test",
        "build:toc",
        "build:prefix-map"
      ],
      "outputs": ["build/**", "next/**", "dist/**"]
    },
    "typecheck": {
      "inputs": ["**/*.{ts,tsx}", "tsconfig*.json", "package.json"]
    },
    "lint": {
      "inputs": ["**/*.{ts,tsx,js,jsx,mjs,cjs}", "eslint.config.*", ".eslintrc.*", "package.json"]
    },
    "lint:fix": {},
    "test": {},
    "test:coverage": {},
    "test:update": {
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "convert:rst-to-mdx": {
      "dependsOn": [],
      "cache": false
    },
    "build:offline": {
      "dependsOn": ["build:prefix-map"],
      "cache": false
    },
    "validate:mdx-parse": {
      "cache": false
    }
  }
}
