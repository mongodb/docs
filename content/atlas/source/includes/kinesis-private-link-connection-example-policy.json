{
   "Version":"2012-10-17",
   "Statement":[
      {
         "Sid": "ExamplePolicy",
         "Effect": "Allow",
         "Principal":{
            "AWS":"<yourAtlasAWSAccountArn>"
         },
         "Action": [
            "kinesis:ListShards",
            "kinesis:DescribeStreamSummary",
            "kinesis:SubscribeToShard",
            "kinesis:PutRecords"
         ],
         "Resource": [
            "arn:aws:kinesis:<awsRegion>:<awsAccountId>:stream/<kinesisStreamName>",
            "arn:aws:kinesis:*:<awsAccountId>:*/*/consumer/*:*"
         ]
      }
   ]
}