{
  "name": "mongodb-mongocli-toc-generator",
  "version": "1.0.0",
  "description": "Generates TypeScript table of contents entries for MongoCLI commands",
  "main": "generate-mongocli-commands.ts",
  "type": "module",
  "scripts": {
    "generate": "npx tsx generate-mongocli-commands.ts",
    "generate-cli:latest": "npx tsx generate-mongocli-commands.ts mongocli/v2.0.7",
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist/ *.js *.js.map generation-summary.json"
  },
  "keywords": [
    "mongodb",
    "mongocli",
    "documentation",
    "table-of-contents",
    "automation"
  ],
  "author": "MongoDB Documentation Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
